#
# shell/zprofile
# zsh ログインシェルで必要な設定。
# POSIX 互換の設定は shell/profile に書き、ここで source する。
#

# --------------------------------------------------------
# POSIX 互換の共通設定を読み込む
# --------------------------------------------------------
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# --------------------------------------------------------
# PATH 重複排除（zsh 専用）
# --------------------------------------------------------
typeset -gU cdpath fpath mailpath path
