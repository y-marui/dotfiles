# --------------------------------------------------------
# 5. SSH ラッパー（Zellij 内のみ有効）
# --------------------------------------------------------
# Zellij 内で ssh を実行すると新しいペイン/タブを作成して SSH を起動する。
# 接続先ではデフォルトで zellij auto-attach（NO_ZELLIJ='' を渡す）。
# --new: 新規タブで開く（デフォルトは縦分割ペイン）。
# --no-zellij: 接続先の zellij auto-attach を無効化（NO_ZELLIJ=1 を渡す）。
# iTerm2 の場合は osascript でタブ/ペインを開く。それ以外は Zellij コマンドを使う。
if [[ -n "$ZELLIJ" ]]; then
  function ssh() {
    local new_tab=false
    local no_zellij=false
    local args=()
    for arg in "$@"; do
      case "$arg" in
        --new)       new_tab=true ;;
        --no-zellij) no_zellij=true ;;
        *)           args+=("$arg") ;;
      esac
    done

    local no_zellij_env="NO_ZELLIJ=''"
    $no_zellij && no_zellij_env="NO_ZELLIJ=1"

    local cmd="env $no_zellij_env command ssh$(printf ' %q' "${args[@]}")"
    local host="${args[-1]}"

    if [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
      if $new_tab; then
        osascript <<EOF
tell application "iTerm2"
  tell current window
    create tab with profile "No Zellij"
    tell current session
      write text "$cmd; exit"
    end tell
  end tell
end tell
EOF
      else
        osascript <<EOF
tell application "iTerm2"
  tell current session of current window
    set newSession to (split vertically with profile "No Zellij")
  end tell
  tell newSession
    write text "$cmd; exit"
  end tell
end tell
EOF
      fi
    else
      if $new_tab; then
        zellij action new-tab --name "ssh:${host}" --close-on-exit -- sh -c "$cmd"
      else
        zellij run --name "ssh:${host}" --close-on-exit -- sh -c "$cmd"
      fi
    fi
  }

  # ssh wrapper のカスタムオプション補完（既存の _ssh 補完に追加）
  function _ssh_zellij_wrapper() {
    local -a wrapper_opts
    wrapper_opts=(
      '--new:現在のタブを分割せず、新規タブで接続する'
      '--no-zellij:接続先でZellijを自動起動しない'
    )
    _describe -t ssh-wrapper-opts 'wrapper options' wrapper_opts

    # _ssh にカスタムフラグを見せないよう words から除外して委譲
    local -a filtered_words
    for w in "${words[@]}"; do
      [[ "$w" == --new || "$w" == --no-zellij ]] || filtered_words+=("$w")
    done
    words=("${filtered_words[@]}")
    (( CURRENT = ${#words[@]} ))
    _ssh
  }
  compdef _ssh_zellij_wrapper ssh
fi

