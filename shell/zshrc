  eval "$(rbenv init -)"                                  # [共通]
fi                                                        # [共通]

# plenv                                                   # [共通]
if command -v plenv > /dev/null; then                     # [共通]
  eval "$(plenv init -)"                                  # [共通]
fi                                                        # [共通]

# gh CLI 補完
if command -v gh &>/dev/null; then
  eval "$(gh completion -s zsh)"
fi

# --------------------------------------------------------
# 8. Powerlevel10k テーマ
# --------------------------------------------------------
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# --------------------------------------------------------
# 9. ローカル設定（シークレット等 → ~/.zshrc.local に記載）
# --------------------------------------------------------
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# --------------------------------------------------------
# 10. ホスト固有設定（$DOTFILES_DIR/host/<hostname>.zsh）（.zshrc.local で DOTFILES_DIR が確定した後）
# --------------------------------------------------------
[[ -f "$DOTFILES_DIR/host/$(hostname -s).zsh" ]] && \
  source "$DOTFILES_DIR/host/$(hostname -s).zsh"

# --------------------------------------------------------
# 1. dotfiles の未コミット・未プッシュを確認（p10k instant prompt より前に出力）
# --------------------------------------------------------
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

if [[ -n "${DOTFILES_DIR:-}" && -d "$DOTFILES_DIR/.git" ]]; then
  _df_msg=()
  if ! git -C "$DOTFILES_DIR" diff --quiet 2>/dev/null || \
     ! git -C "$DOTFILES_DIR" diff --cached --quiet 2>/dev/null; then
    _df_msg+=("未コミットの変更あり")
  fi
  _df_unpushed=$(git -C "$DOTFILES_DIR" log '@{u}..' --oneline 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${_df_unpushed}" -gt 0 ]]; then
    _df_msg+=("${_df_unpushed} commits unpushed")
  fi
  if [[ ${#_df_msg[@]} -gt 0 ]]; then
    print -P "%F{yellow}⚠ dotfiles: ${(j: / :)_df_msg}%f"
  fi
  unset _df_msg _df_unpushed
fi

# --------------------------------------------------------
# 2. dotfiles-private の未コミット・未プッシュを確認
# --------------------------------------------------------
_dfp_dir="${DOTFILES_DIR}-private"
if [[ -d "${_dfp_dir}/.git" ]]; then
  _dfp_msg=()
  if ! git -C "$_dfp_dir" diff --quiet 2>/dev/null || \
     ! git -C "$_dfp_dir" diff --cached --quiet 2>/dev/null; then
    _dfp_msg+=("未コミットの変更あり")
  fi
  _dfp_unpushed=$(git -C "$_dfp_dir" log '@{u}..' --oneline 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${_dfp_unpushed}" -gt 0 ]]; then
    _dfp_msg+=("${_dfp_unpushed} commits unpushed")
  fi
  if [[ ${#_dfp_msg[@]} -gt 0 ]]; then
    print -P "%F{yellow}⚠ dotfiles-private: ${(j: / :)_dfp_msg}%f"
  fi
  unset _dfp_msg _dfp_unpushed
fi
unset _dfp_dir

