# shell/zshrc
# zsh 対話シェルの設定。
# [共通] マークは bashrc と内容を共有していることを示す。

if command -v zellij >/dev/null 2>&1; then
  function auto_zellij() {
    if [[ "$TERM_PROGRAM" == "iTerm.app" && -z "$ZELLIJ" ]]; then
      local name="${HOST%%.*}"
      zellij attach -c "$name"
      exit
    fi
  }

  auto_zellij
else
  print -P "%F{yellow}Zellij is not installed, so running in a normal zsh shell.%f"
fi


# --------------------------------------------------------
# 1. Powerlevel10k instant prompt（最上部に置くこと）
# --------------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --------------------------------------------------------
# 2. zprezto
# --------------------------------------------------------
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# --------------------------------------------------------
# 3. zsh オプション
# --------------------------------------------------------
setopt IGNOREEOF        # Ctrl+D でのログアウトを防ぐ
setopt COMPLETE_IN_WORD # 単語の途中でも補完する

# --------------------------------------------------------
# 4. 補完
# --------------------------------------------------------
autoload -Uz colors && colors
autoload -U compinit
fpath+=$(brew --prefix)/share/zsh/site-functions
compinit
autoload -U bashcompinit && bashcompinit

# --------------------------------------------------------
# 5. エイリアス
# --------------------------------------------------------
alias py='python'       # [共通]
alias ipy='ipython'     # [共通]
alias ls='/bin/ls -G'   # [共通]
alias pbg='ghq list -p | sort -fV | fzf | pbcopy'
# pyenv と brew の PATH 衝突回避 + Brewfile.cache 自動更新
function brew() {
  env PATH="${PATH//${PYENV_ROOT}/bin:/}" brew "$@"
  case "$1" in
    install|uninstall|tap|untap|upgrade)
      bash "$DOTFILES_DIR/macos/update_brewcache.sh" 2>/dev/null || true
      ;;
  esac
}

# npm グローバルパッケージ操作時に npmfile.cache 自動更新
function npm() {
  command npm "$@"
  case "$1" in
    install|uninstall|update)
      if [[ "${2:-}" == "-g" || "${2:-}" == "--global" ]]; then
        bash "$DOTFILES_DIR/npm/update_npmcache.sh" 2>/dev/null || true
      fi
      ;;
  esac
}

# --------------------------------------------------------
# 6. カスタム関数
# --------------------------------------------------------

# ghq + fzf でリポジトリ移動
compdef _g g
function g() {
  case "$1" in
    root)
      git config ghq.root;;
    *)
      local target
      target="$(ghq list -p | sort -fV | fzf)"
      echo "$target"
      if [ -n "$target" ]; then
        cd "$target"
      fi;;
  esac
}
function _g() { _values '' 'root' }

# ghq リポジトリの local.keep-up-to-date 状態を一覧表示
function ghq-status() {
  local root val rel repo
  root="$(ghq root)"
  while IFS= read -r repo; do
    val="$(git -C "$repo" config local.keep-up-to-date 2>/dev/null || true)"
    rel="${repo#"$root/"}"
    if [[ "$val" == "true" ]]; then
      printf "\e[32m[keep]\e[m  %s\n" "$rel"
    elif [[ "$val" == "false" ]]; then
      printf "\e[31m[skip]\e[m  %s\n" "$rel"
    else
      printf "[----]  %s\n" "$rel"
    fi
  done < <(ghq list -p | sort -fV)
}

# cd 後に自動で ls
function cd() {
  builtin cd "$@" && ls
}

# ディレクトリによって code / code-insiders を切り替え
function code() {
  local target
  target="$(pwd)"
  if [[ -n "$1" ]]; then
    target="$(builtin cd "$1"; pwd)"
  fi
  if [[ "$target" =~ "$(ghq root)/github.com/y-muen/*" ]]; then
    command code-insiders "$@"
  else
    command code "$@"
  fi
}

# pip search を pip_search にリダイレクト
function pip() {
  if [[ $1 = "search" ]]; then
    pip_search "$2"
  else
    command pip "$@"
  fi
}
function _pip {
  local words cword
  read -Ac words
  read -cn cword
  reply=( $( COMP_WORDS="$words[*]" \
             COMP_CWORD=$(( cword-1 )) \
             PIP_AUTO_COMPLETE=1 $words[1] 2>/dev/null ))
}
compctl -K _pip pip

# keep-up-to-date フラグが立っているリポジトリを一括更新
# --pull: git pull のみ実行（poetry update をスキップ）
function ghq-update() {
  local pull_only=false
  [[ "${1:-}" == "--pull" ]] && pull_only=true

  local f
  for f in $(ghq list -p); do
    (
      builtin cd "$f" || continue
      if [[ "$(git config --bool local.keep-up-to-date 2>/dev/null)" == "true" ]]; then
        echo ""
        pwd
        ls
        git pull
        if [[ "$pull_only" == "false" ]] && [[ -d .venv ]]; then
          poetry update
        fi
      fi
    )
  done
}

# --------------------------------------------------------
# 7. ツール初期化
# --------------------------------------------------------

# pyenv                                                   # [共通]
if command -v pyenv > /dev/null; then                     # [共通]
  eval "$(pyenv init -)"                                  # [共通]
  eval "$(pyenv init --path)"                             # [共通]
fi                                                        # [共通]

# rbenv                                                   # [共通]
