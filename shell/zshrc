# shell/zshrc
# zsh 対話シェルの設定。
# [共通] マークは bashrc と内容を共有していることを示す。

# --------------------------------------------------------
# 0. SSH エージェントソケットの固定化（Zellij 再アタッチ対応）
# --------------------------------------------------------
# SSH ログインのたびに ~/.ssh/auth_sock を最新のソケットへ更新する。
# Zellij 既存セッションに再アタッチした後も有効なソケットを参照できるようにする。
if [[ -n "$SSH_CONNECTION" && -n "$SSH_AUTH_SOCK" && "$SSH_AUTH_SOCK" != "$HOME/.ssh/auth_sock" ]]; then
  ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth_sock"
fi
[[ -e "$HOME/.ssh/auth_sock" ]] && export SSH_AUTH_SOCK="$HOME/.ssh/auth_sock"

# --------------------------------------------------------
# 1. Zellijの自動アタッチ
# --------------------------------------------------------

# Zellij セッションに自動アタッチ（セッション名はホスト名）
# iTerm.app / Windows Terminal（WSL）/ SSH 接続時のみ起動。NO_ZELLIJ=1 でスキップ。
if command -v zellij >/dev/null 2>&1 && [[ -z "$ZELLIJ" && -z "$NO_ZELLIJ" ]]; then
  if [[ "$TERM_PROGRAM" == "iTerm.app" || -n "$WT_SESSION" || -n "$SSH_CONNECTION" ]]; then
    zellij attach -c "${HOST%%.*}"
    exit
  fi
fi

# --------------------------------------------------------
# 1. Powerlevel10k instant prompt（最上部に置くこと）
# --------------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --------------------------------------------------------
# 2. zprezto
# --------------------------------------------------------
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# --------------------------------------------------------
# 3. zsh オプション
# --------------------------------------------------------
setopt IGNOREEOF        # Ctrl+D でのログアウトを防ぐ
setopt COMPLETE_IN_WORD # 単語の途中でも補完する

# --------------------------------------------------------
# 4. 補完
# --------------------------------------------------------
autoload -Uz colors && colors
autoload -U compinit
fpath+=$(brew --prefix)/share/zsh/site-functions
compinit
autoload -U bashcompinit && bashcompinit

# --------------------------------------------------------
# 5. SSH ラッパー（Zellij 内のみ有効）
# --------------------------------------------------------
# Zellij 内で ssh を実行すると新しいペイン/タブを作成して SSH を起動する。
# 接続先ではデフォルトで zellij auto-attach（NO_ZELLIJ='' を渡す）。
# --new: 新規タブで開く（デフォルトは縦分割ペイン）。
# --no-zellij: 接続先の zellij auto-attach を無効化（NO_ZELLIJ=1 を渡す）。
# iTerm2 の場合は osascript でタブ/ペインを開く。それ以外は Zellij コマンドを使う。
if [[ -n "$ZELLIJ" ]]; then
  function ssh() {
    local new_tab=false
    local no_zellij=false
    local args=()
    for arg in "$@"; do
      case "$arg" in
        --new)       new_tab=true ;;
        --no-zellij) no_zellij=true ;;
        *)           args+=("$arg") ;;
      esac
    done

    local no_zellij_env="NO_ZELLIJ=''"
    $no_zellij && no_zellij_env="NO_ZELLIJ=1"

    # ホスト名を探し、リモートコマンドの有無を判定する
    # 値を取る SSH オプション: -b -c -D -E -e -F -I -i -J -L -l -m -o -p -Q -R -S -W -w
    local skip_next=false
    local host=""
    local has_remote_cmd=false
    for arg in "${args[@]}"; do
      if $skip_next; then
        skip_next=false
        continue
      fi
      if [[ "$arg" == -[bcDEeFIiJLlmopQRSWw] ]]; then
        skip_next=true
        continue
      fi
      [[ "$arg" == -* ]] && continue
      if [[ -z "$host" ]]; then
        host="$arg"
      else
        has_remote_cmd=true
        break
      fi
    done

    # リモートコマンドあり → インタラクティブではないので直接実行
    if $has_remote_cmd; then
      command ssh "${args[@]}"
      return
    fi

    local cmd="env $no_zellij_env command ssh$(printf ' %q' "${args[@]}")"

    if [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
      if $new_tab; then
        osascript <<EOF
tell application "iTerm2"
  tell current window
    create tab with profile "No Zellij"
    tell current session
      write text "$cmd; exit"
    end tell
  end tell
end tell
EOF
      else
        osascript <<EOF
tell application "iTerm2"
  tell current session of current window
    set newSession to (split vertically with profile "No Zellij")
  end tell
  tell newSession
    write text "$cmd; exit"
  end tell
end tell
EOF
      fi
    else
      if $new_tab; then
        zellij action new-tab --name "ssh:${host}" --close-on-exit -- sh -c "$cmd"
      else
        zellij run --name "ssh:${host}" --close-on-exit -- sh -c "$cmd"
      fi
    fi
  }

  # ssh wrapper のカスタムオプション補完（既存の _ssh 補完に追加）
  function _ssh_zellij_wrapper() {
    local -a wrapper_opts
    wrapper_opts=(
      '--new:現在のタブを分割せず、新規タブで接続する'
      '--no-zellij:接続先でZellijを自動起動しない'
    )
    _describe -t ssh-wrapper-opts 'wrapper options' wrapper_opts

    # _ssh にカスタムフラグを見せないよう words から除外して委譲
    local -a filtered_words
    for w in "${words[@]}"; do
      [[ "$w" == --new || "$w" == --no-zellij ]] || filtered_words+=("$w")
    done
    words=("${filtered_words[@]}")
    (( CURRENT = ${#words[@]} ))
    _ssh
  }
  compdef _ssh_zellij_wrapper ssh
fi

# --------------------------------------------------------
# 7. エイリアス
# --------------------------------------------------------
alias py='python'       # [共通]
alias ipy='ipython'     # [共通]
alias ls='/bin/ls -G'   # [共通]
alias pbg='ghq list -p | sort -fV | fzf | pbcopy'
# pyenv と brew の PATH 衝突回避 + Brewfile.cache 自動更新
function brew() {
  env PATH="${PATH//${PYENV_ROOT}/bin:/}" brew "$@"
  case "$1" in
    install|uninstall|tap|untap|upgrade)
      bash "$DOTFILES_DIR/macos/update_brewcache.sh" 2>/dev/null || true
      ;;
  esac
}

# npm グローバルパッケージ操作時に npmfile.cache 自動更新
function npm() {
  command npm "$@"
  case "$1" in
    install|uninstall|update)
      if [[ "${2:-}" == "-g" || "${2:-}" == "--global" ]]; then
        bash "$DOTFILES_DIR/npm/update_npmcache.sh" 2>/dev/null || true
      fi
      ;;
  esac
}

# --------------------------------------------------------
# 8. カスタム関数
# --------------------------------------------------------

# ghq + fzf でリポジトリ移動
compdef _g g
function g() {
  case "$1" in
    root)
      git config ghq.root;;
    *)
      local target
      target="$(ghq list -p | sort -fV | fzf)"
      echo "$target"
      if [ -n "$target" ]; then
        cd "$target"
      fi;;
  esac
}
function _g() { _values '' 'root' }

# cd 後に自動で ls
function cd() {
  builtin cd "$@" && ls
}

# ディレクトリによって code / code-insiders を切り替え
function code() {
  local target
  target="$(pwd)"
  if [[ -n "$1" ]]; then
    target="$(builtin cd "$1"; pwd)"
  fi
  if [[ "$target" =~ "$(ghq root)/github.com/y-muen/*" ]]; then
    command code-insiders "$@"
  else
    command code "$@"
  fi
}

# pip は禁止: pipx（コマンド）または uv（開発）を使う
function pip() {
  echo "pip は使用禁止です。pipx または uv を使ってください。" >&2
  return 1
}

# claude-rc: リモートで claude remote-control を起動
# デスクトップの ghq リポジトリを fzf で選択し、
# リモートの zellij 新タブで claude remote-control を起動する。
#
# 使い方: claude-rc <hostname> [-w|-s|--session]
#   (なし)          same-dir モード（デフォルト）
#   -w, --worktree  worktree モード
#   -s, --session   session モード（1セッションのみ）
function claude-rc() {
  local host="${1:?Usage: claude-rc <hostname> [-w|--worktree] [-s|--session]}"
  local spawn="same-dir"

  case "${2:-}" in
    -w|--worktree) spawn="worktree" ;;
    -s|--session)  spawn="session"  ;;
  esac

  local target session
  target="$(ssh "$host" "zsh -lc 'ghq list --full-path'" 2>/dev/null | sort -fV | fzf --prompt="claude-rc [$host]> ")"
  [[ -z "$target" ]] && return

  session="$(ssh "$host" "hostname -s")"
  local name="claude:$(basename "$target")"
  [[ "$spawn" != "same-dir" ]] && name="$name[$spawn]"

  ssh "$host" "zellij --session '$session' action new-tab \
    --name '$name' \
    --cwd '$target' \
    -- claude remote-control --spawn='$spawn'"
}

function _claude-rc() {
  _arguments \
    '1:hostname:_ssh_hosts' \
    '2:spawn mode:((-w\:worktree\ mode -s\:session\ mode --worktree\:worktree\ mode --session\:session\ mode))'
}
compdef _claude-rc claude-rc

# --------------------------------------------------------
# 9. ツール初期化
# --------------------------------------------------------

# pyenv                                                   # [共通]
if command -v pyenv > /dev/null; then                     # [共通]
  eval "$(pyenv init -)"                                  # [共通]
  eval "$(pyenv init --path)"                             # [共通]
fi                                                        # [共通]

# rbenv                                                   # [共通]
if command -v rbenv > /dev/null; then                     # [共通]
  eval "$(rbenv init -)"                                  # [共通]
fi                                                        # [共通]

# plenv                                                   # [共通]
if command -v plenv > /dev/null; then                     # [共通]
  eval "$(plenv init -)"                                  # [共通]
fi                                                        # [共通]

# gh CLI 補完
if command -v gh &>/dev/null; then
  eval "$(gh completion -s zsh)"
fi

# --------------------------------------------------------
# 10. Powerlevel10k テーマ
# --------------------------------------------------------
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# --------------------------------------------------------
# 11. ローカル設定（シークレット等 → ~/.zshrc.local に記載）
# --------------------------------------------------------
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# --------------------------------------------------------
# 12. ホスト固有設定（$DOTFILES_DIR/host/<hostname>.zsh）（.zshrc.local で DOTFILES_DIR が確定した後）
# --------------------------------------------------------
[[ -f "$DOTFILES_DIR/host/$(hostname -s).zsh" ]] && \
  source "$DOTFILES_DIR/host/$(hostname -s).zsh"

# --------------------------------------------------------
# 1. dotfiles の未コミット・未プッシュを確認（p10k instant prompt より前に出力）
# --------------------------------------------------------
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet

if [[ -n "${DOTFILES_DIR:-}" && -d "$DOTFILES_DIR/.git" ]]; then
  _df_msg=()
  if ! git -C "$DOTFILES_DIR" diff --quiet 2>/dev/null || \
     ! git -C "$DOTFILES_DIR" diff --cached --quiet 2>/dev/null; then
    _df_msg+=("未コミットの変更あり")
  fi
  _df_unpushed=$(git -C "$DOTFILES_DIR" log '@{u}..' --oneline 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${_df_unpushed}" -gt 0 ]]; then
    _df_msg+=("${_df_unpushed} commits unpushed")
  fi
  if [[ ${#_df_msg[@]} -gt 0 ]]; then
    print -P "%F{yellow}⚠ dotfiles: ${(j: / :)_df_msg}%f"
  fi
  unset _df_msg _df_unpushed
fi

# --------------------------------------------------------
# 2. dotfiles-private の未コミット・未プッシュを確認
# --------------------------------------------------------
_dfp_dir="${DOTFILES_DIR}-private"
if [[ -d "${_dfp_dir}/.git" ]]; then
  _dfp_msg=()
  if ! git -C "$_dfp_dir" diff --quiet 2>/dev/null || \
     ! git -C "$_dfp_dir" diff --cached --quiet 2>/dev/null; then
    _dfp_msg+=("未コミットの変更あり")
  fi
  _dfp_unpushed=$(git -C "$_dfp_dir" log '@{u}..' --oneline 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${_dfp_unpushed}" -gt 0 ]]; then
    _dfp_msg+=("${_dfp_unpushed} commits unpushed")
  fi
  if [[ ${#_dfp_msg[@]} -gt 0 ]]; then
    print -P "%F{yellow}⚠ dotfiles-private: ${(j: / :)_dfp_msg}%f"
  fi
  unset _dfp_msg _dfp_unpushed
fi
unset _dfp_dir

# --------------------------------------------------------
# 3. Brewfile.cache と Brewfile の乖離確認（ファイル比較のみ・brew 実行なし）
# --------------------------------------------------------
if [[ -n "${DOTFILES_DIR:-}" && -f "$DOTFILES_DIR/macos/Brewfile.cache" ]]; then
  _brew_diff=$(bash "$DOTFILES_DIR/macos/diff_brewfile.sh" --summary 2>/dev/null || true)
  if [[ -n "$_brew_diff" ]]; then
    print -P "%F{yellow}⚠ brew: $_brew_diff (make brew-diff で確認)%f"
  fi
  unset _brew_diff
fi

# --------------------------------------------------------
# 4. npmfile.cache と npmfile の乖離確認（ファイル比較のみ・npm 実行なし）
# --------------------------------------------------------
if [[ -n "${DOTFILES_DIR:-}" && -f "$DOTFILES_DIR/npm/npmfile.cache" ]]; then
  _npm_diff=$(bash "$DOTFILES_DIR/npm/diff_npmfile.sh" --summary 2>/dev/null || true)
  if [[ -n "$_npm_diff" ]]; then
    print -P "%F{yellow}⚠ npm: $_npm_diff (make npm-diff で確認)%f"
  fi
  unset _npm_diff
fi

# --------------------------------------------------------
# 5. pipxfile.cache と pipxfile の乖離確認（ファイル比較のみ・pipx 実行なし）
# --------------------------------------------------------
if [[ -n "${DOTFILES_DIR:-}" && -f "$DOTFILES_DIR/pipx/pipxfile.cache" ]]; then
  _pipx_diff=$(bash "$DOTFILES_DIR/pipx/diff_pipxfile.sh" --summary 2>/dev/null || true)
  if [[ -n "$_pipx_diff" ]]; then
    print -P "%F{yellow}⚠ pipx: $_pipx_diff (make pipx-diff で確認)%f"
  fi
  unset _pipx_diff
fi

# --------------------------------------------------------
# 6. dock の乖離確認（dock.cache と dock.sh のファイル比較のみ・dockutil 実行なし）
# --------------------------------------------------------
if [[ -n "${DOTFILES_DIR:-}" ]]; then
  _dock_diff=$(bash "$DOTFILES_DIR/macos/diff_dockfile.sh" --summary 2>/dev/null || true)
  if [[ -n "$_dock_diff" ]]; then
    print -P "%F{yellow}⚠ dock: $_dock_diff (make dock-diff で確認)%f"
  fi
  unset _dock_diff
fi

# iTerm2 Shell Integration を読み込む（iTerm2 で zsh を使う場合は必須）
if [[ "$TERM_PROGRAM" == "iTerm.app" ]]; then
  if [[ ! -f ~/.iterm2_shell_integration.zsh || ! -f ~/.iterm2_shell_integration.zsh ]]; then
	  echo "Install Shell Integration on iTerm2."
  else
    test -e ~/.iterm2_shell_integration.zsh1 && source ~/.iterm2_shell_integration.zsh || true
  fi
fi
