# ~/.profile / shell/profile
# sh 互換構文のみ。全シェル（zsh/bash）共通の環境変数・PATH。
# shellcheck shell=sh

# --------------------------------------------------------
# DOTFILES_DIR（bash / zsh 共通）
# --------------------------------------------------------
export DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/dotfiles}"

# --------------------------------------------------------
# Editors / Pager
# --------------------------------------------------------
export EDITOR='vim'
export VISUAL='vim'
export PAGER='less'

# --------------------------------------------------------
# Language
# --------------------------------------------------------
export LANG='ja_JP.UTF-8'

# --------------------------------------------------------
# Less
# --------------------------------------------------------
export LESS='-R'
if [ -x "$(command -v src-hilite-lesspipe.sh)" ]; then
  export LESSOPEN="| src-hilite-lesspipe.sh %s"
fi

# --------------------------------------------------------
# Python (pyenv)
# --------------------------------------------------------
export PYENV_ROOT="$HOME/.pyenv"
export PYENV_VIRTUALENV_DISABLE_PROMPT=1
export PYTHONPYCACHEPREFIX="$HOME/.config/pycache"

# --------------------------------------------------------
# PATH
# --------------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.rbenv/shims:$PATH"
export PATH="$HOME/.nodebrew/current/bin:$PATH"

# --------------------------------------------------------
# Cloud storage roots（$HOME 相対なのでポータブル）
# --------------------------------------------------------
export GOOGLEDRIVE_ROOT="$HOME/Public/GoogleDrive"
export DROPBOX_ROOT="$HOME/Public/Dropbox"
export ICLOUD_ROOT="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
export ZOTERO_ROOT="$HOME/Library/Mobile Documents/3L68KQB4HG~com~readdle~CommonDocuments/Documents/Zotero Library"

# --------------------------------------------------------
# Misc
# --------------------------------------------------------
export DICTIONARY='en_US'

# --------------------------------------------------------
# Browser (macOS)
# --------------------------------------------------------
if [ "$(uname)" = Darwin ]; then
  export BROWSER='open'
fi

# --------------------------------------------------------
# Homebrew
# --------------------------------------------------------
if [ -d '/opt/homebrew' ]; then
  export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
fi
export PATH="/usr/local/bin:/usr/local/sbin:$PATH"

if [ -d '/opt/homebrew/opt/openssl@3' ]; then
  export PATH="/opt/homebrew/opt/openssl@3/bin:$PATH"
fi

# --------------------------------------------------------
# TeX
# --------------------------------------------------------
export PATH="/Library/TeX/texbin:$PATH"

# --------------------------------------------------------
# Homebrew: misc
# --------------------------------------------------------
export XML_CATALOG_FILES='/opt/homebrew/etc/xml/catalog'

# --------------------------------------------------------
# コンパイラ・ライブラリフラグ（brew install したライブラリに依存）
# マシン固有のものは host/<hostname>.sh へ記載してください
# --------------------------------------------------------
export CPPFLAGS="-I/opt/homebrew/opt/sqlite/include${CPPFLAGS:+ $CPPFLAGS}"
export PKG_CONFIG_PATH="/opt/homebrew/opt/sqlite/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
