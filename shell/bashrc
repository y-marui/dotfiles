# shell/bashrc
# bash 対話シェルの設定。
# shellcheck shell=bash

# --------------------------------------------------------
# 共通設定の読み込み
# --------------------------------------------------------
# shellcheck source=shell/profile
[ -f "$HOME/.profile" ] && . "$HOME/.profile"

# --------------------------------------------------------
# エイリアス（bash 互換のもの）
# --------------------------------------------------------
alias py='python'
alias ipy='ipython'
alias ls='/bin/ls -G'
alias tree='tree -C'
alias ffmpeg='/usr/local/bin/ffmpeg'
alias blender='/Applications/blender.app/Contents/MacOS/blender'
alias gcc='/usr/bin/gcc'
alias g++='/usr/bin/g++'

# --------------------------------------------------------
# bash-completion (Homebrew)
# --------------------------------------------------------
[ -f /usr/local/etc/bash_completion ] && . /usr/local/etc/bash_completion

# --------------------------------------------------------
# ツール初期化
# --------------------------------------------------------

# pyenv
if command -v pyenv > /dev/null; then
  eval "$(pyenv init -)"
fi

# rbenv
if command -v rbenv > /dev/null; then
  eval "$(rbenv init -)"
fi

# plenv
if command -v plenv > /dev/null; then
  eval "$(plenv init -)"
fi

# gh CLI 補完
if command -v gh > /dev/null; then
  eval "$(gh completion -s bash)"
fi

# --------------------------------------------------------
# ホスト固有設定（$DOTFILES_DIR/host/<hostname>.bash）
# --------------------------------------------------------
# shellcheck disable=SC1090
[ -f "$DOTFILES_DIR/host/$(hostname -s).bash" ] && \
  . "$DOTFILES_DIR/host/$(hostname -s).bash"
