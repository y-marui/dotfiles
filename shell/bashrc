# shell/bashrc
# bash 対話シェルの設定。

# --------------------------------------------------------
# 共通設定の読み込み
# --------------------------------------------------------
[[ -f "$HOME/.profile" ]] && source "$HOME/.profile"

# --------------------------------------------------------
# エイリアス（bash 互換のもの）
# --------------------------------------------------------
alias py='python'
alias ipy='ipython'
alias ls='/bin/ls -G'
alias tree='tree -C'
alias ffmpeg='/usr/local/bin/ffmpeg'
alias blender='/Applications/blender.app/Contents/MacOS/blender'
alias gcc='/usr/bin/gcc'
alias g++='/usr/bin/g++'

# --------------------------------------------------------
# ホスト固有設定（$HOME/dotfiles/host/<hostname>.bash）
# --------------------------------------------------------
[[ -f "$HOME/dotfiles/host/$(hostname -s).bash" ]] && \
  source "$HOME/dotfiles/host/$(hostname -s).bash"
