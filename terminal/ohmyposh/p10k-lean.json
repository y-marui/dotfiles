{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "white",
          "template": "{{ .Icon }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#0087af",
          "template": "{{ .Path }}",
          "properties": {
            "style": "mixed",
            "mixed_threshold": 4,
            "folder_separator_icon": "/",
            "home_icon": "~"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#5fd700",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#d7af00{{ end }}"
          ],
          "template": " \uF126 {{ .HEAD }}{{ if gt .Behind 0 }} ⇣{{ .Behind }}{{ end }}{{ if gt .Ahead 0 }}⇡{{ .Ahead }}{{ end }}{{ if gt .StashCount 0 }} *{{ .StashCount }}{{ end }}{{ if .Staging.Changed }} +{{ end }}{{ if gt .Working.Modified 0 }} !{{ .Working.Modified }}{{ end }}{{ if gt .Working.Untracked 0 }} ?{{ .Working.Untracked }}{{ end }}",
          "properties": {
            "fetch_status": true,
            "fetch_stash_count": true,
            "branch_max_length": 32,
            "truncate_symbol": "…"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "foreground": "#d7af00",
          "template": "✘ {{ .Code }}",
          "properties": {
            "always_enabled": false
          }
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#d7af00",
          "template": "  {{ .FormattedMs }}",
          "properties": {
            "threshold": 3000,
            "style": "round"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#808080",
          "template": "  {{ .CurrentDate | date \"15:04:05\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#5fd700",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff0000{{ end }}"
          ],
          "template": "❯ "
        }
      ]
    }
  ]
}
