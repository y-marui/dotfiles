#compdef install-my-apps

_install-my-apps_apps() {
  local build_dir="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Build"
  local -a apps
  for dmg in "$build_dir"/*.dmg(N); do
    apps+=("${${dmg##*/}%.dmg}")
  done
  _describe 'app' apps
}

_install-my-apps() {
  _arguments \
    '(-r --reinstall)'{-r,--reinstall}'[削除してからインストール（再インストールモード）]' \
    '*:app:_install-my-apps_apps'
}

_install-my-apps "$@"
