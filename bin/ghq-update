#!/usr/bin/env bash
# ghq-update: ghq 管理リポジトリを更新する
#
# 使い方:
#   ghq-update [options]
#
# オプション:
#   --all        全リポジトリを fetch + pull し、uv sync は keep-up-to-date=true のみ
#                （省略時は keep-up-to-date=true のリポジトリのみ pull + uv sync）
#   --pull-only  uv sync --upgrade をスキップ
#   -h, --help   ヘルプを表示
#
# 動作:
#   デフォルト:
#     - keep-up-to-date=true のリポジトリのみ git pull --ff-only
#     - .venv があれば uv sync --upgrade
#   --all:
#     - 全リポジトリを git fetch origin --prune + git pull --ff-only
#     - detached HEAD・upstream 未設定・ワーキングツリーが汚い場合は pull をスキップ
#     - .venv があり keep-up-to-date=true のリポジトリのみ uv sync --upgrade

set -euo pipefail

ALL=false
PULL_ONLY=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)      ALL=true; shift ;;
    --pull-only) PULL_ONLY=true; shift ;;
    -h|--help)  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)          echo "error: unknown option: $1" >&2; exit 1 ;;
  esac
done

if ! command -v ghq >/dev/null 2>&1; then
  echo "error: 'ghq' が見つかりません。" >&2
  exit 1
fi

while IFS= read -r f; do
  echo ""
  echo "==> $f"

  if [[ "$ALL" == true ]]; then
    git -C "$f" fetch origin --prune || true
    git -C "$f" symbolic-ref --short HEAD &>/dev/null || { echo "  [skip] detached HEAD"; continue; }
    git -C "$f" rev-parse "@{u}" &>/dev/null || { echo "  [skip] no upstream"; continue; }
    if [[ -n "$(git -C "$f" status --porcelain 2>/dev/null)" ]]; then
      echo "  [skip pull] dirty working tree"
      continue
    fi
    git -C "$f" pull --ff-only || true
    if [[ "$PULL_ONLY" == false ]] && \
       [[ "$(git -C "$f" config --bool local.keep-up-to-date 2>/dev/null)" == "true" ]] && \
       [[ -d "$f/.venv" ]]; then
      (cd "$f" && uv sync --upgrade)
    fi
  else
    if [[ "$(git -C "$f" config --bool local.keep-up-to-date 2>/dev/null)" != "true" ]]; then
      continue
    fi
    git -C "$f" symbolic-ref --short HEAD &>/dev/null || { echo "  [skip] detached HEAD"; continue; }
    git -C "$f" rev-parse "@{u}" &>/dev/null || { echo "  [skip] no upstream"; continue; }
    if [[ -n "$(git -C "$f" status --porcelain 2>/dev/null)" ]]; then
      echo "  [skip pull] dirty working tree"
      continue
    fi
    git -C "$f" pull --ff-only || true
    if [[ "$PULL_ONLY" == false ]] && [[ -d "$f/.venv" ]]; then
      (cd "$f" && uv sync --upgrade)
    fi
  fi
done < <(ghq list -p | sort -fV)
