#!/usr/bin/env bash
# ghq-pull: ghq 管理リポジトリの全リポジトリを fetch + pull する
#
# 使い方:
#   ghq-pull [options]
#
# オプション:
#   --fetch-only        fetch のみ実行（pull をスキップ）
#   -f, --filter PATTERN  リポジトリパスが正規表現 PATTERN にマッチするものだけを対象にする
#   -h, --help          ヘルプを表示
#
# 動作:
#   - git fetch origin --prune を実行する（dirty でも実行）
#   - fetch 失敗・detached HEAD・upstream 未設定・dirty な場合は pull をスキップ
#   - それ以外は git pull --ff-only を実行する

set -euo pipefail

FETCH_ONLY=false
FILTER=''

while [[ $# -gt 0 ]]; do
  case "$1" in
    --fetch-only) FETCH_ONLY=true; shift ;;
    -f|--filter)
      [[ $# -lt 2 ]] && { echo "error: --filter requires an argument" >&2; exit 1; }
      FILTER="$2"; shift 2 ;;
    -h|--help)    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)            echo "error: unknown option: $1" >&2; exit 1 ;;
  esac
done

if ! command -v ghq >/dev/null 2>&1; then
  echo "error: 'ghq' が見つかりません。" >&2
  exit 1
fi

while IFS= read -r f; do
  echo ""
  echo "==> $f"
  if ! git -C "$f" fetch origin --prune; then
    echo "  [skip pull] fetch failed"
    continue
  fi
  if [[ "$FETCH_ONLY" == false ]]; then
    git -C "$f" symbolic-ref --short HEAD &>/dev/null || { echo "  [skip pull] detached HEAD"; continue; }
    git -C "$f" rev-parse "@{u}" &>/dev/null || { echo "  [skip pull] no upstream"; continue; }
    if [[ -n "$(git -C "$f" status --porcelain 2>/dev/null)" ]]; then
      echo "  [skip pull] dirty working tree"
      continue
    fi
    git -C "$f" pull --ff-only || true
  fi
done < <(ghq list -p | sort -fV | grep -iE -- "$FILTER")
