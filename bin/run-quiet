#!/bin/sh
# run-quiet: エラーがなければ1行サマリーを出力するラッパー
# 使い方: run-quiet <command> [args...]

if [ $# -eq 0 ]; then
  echo "usage: run-quiet <command> [args...]" >&2
  exit 1
fi

output=$("$@" 2>&1)
exit_code=$?

if [ "$exit_code" -eq 0 ]; then
  echo "✓ $* succeeded"
  # warning / deprecated / note 行があれば抜粋表示
  warnings=$(echo "$output" | grep -iE "(warning|warn|deprecated|deprecation|note):" || true)
  if [ -n "$warnings" ]; then
    echo "$warnings"
  fi
else
  echo "✗ $* failed (exit $exit_code):"
  echo "$output"
  exit "$exit_code"
fi
