#!/usr/bin/env bash
# 自作アプリを一括インストールするスクリプト
# デフォルト（上書きモード）:
#   同バージョン（DMG のタイムスタンプが同じ）はスキップ
#   1. 起動中のアプリを終了
#   2. DMG からインストール（既存 .app を上書き）
#   3. アプリを起動してウィジェット拡張を登録
#   4. ウィジェット編集画面を開く
# --force / -f フラグ（強制インストールモード）:
#   バージョンチェックをスキップして常にインストール
# --reinstall / -r フラグ（再インストールモード）:
#   同バージョン（DMG のタイムスタンプが同じ）はスキップ
#   1. 起動中のアプリを終了・既存の .app を削除
#   2. ウィジェットキャッシュをクリア
#   3. DMG からインストール
#   4. アプリを起動してウィジェット拡張を登録
#   5. ウィジェット編集画面を開く
# --uninstall / -u フラグ（アンインストールモード）:
#   引数指定時: 指定アプリを削除
#   引数なし: このスクリプトでインストールしたアプリをすべて削除
set -euo pipefail

readonly BUILD_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Build"
readonly APPS_DIR="/Applications"

installed_apps=()

check_icloud_sync() {
    local dir="$1"

    echo ""
    echo "==> iCloud 同期を確認..."

    # フォルダごとダウンロードをトリガー
    brctl download "$dir" 2>/dev/null || true

    # .dmg.icloud プレースホルダが消えるまで待機（最大60秒）
    local waited=0
    while (( waited < 60 )); do
        local remaining=0
        for f in "$dir"/.*.dmg.icloud; do
            [[ -f "$f" ]] && (( remaining++ ))
        done
        (( remaining == 0 )) && break
        sleep 1
        (( waited++ ))
    done

    if (( waited >= 60 )); then
        echo "  警告: ダウンロードがタイムアウトしました（60秒）。続行します..." >&2
    elif (( waited > 0 )); then
        echo "  ダウンロード完了（${waited}秒）"
    fi
}


quit_app() {
    local name="$1"
    local app_path="$APPS_DIR/${name}.app"

    # AppleScript で終了要求
    if osascript -e "tell application \"$name\" to running" 2>/dev/null | grep -q true; then
        echo "  終了中: $name"
        osascript -e "tell application \"$name\" to quit" 2>/dev/null || true
        # 最大 5 秒待機
        local i=0
        while (( i < 10 )); do
            osascript -e "tell application \"$name\" to running" 2>/dev/null | grep -q true || break
            sleep 0.5
            i=$(( i + 1 ))
        done
    fi

    # 残留プロセスを強制終了
    pkill -f "$app_path" 2>/dev/null || true
    sleep 0.3
}

# DMG 内のアプリと Applications 内のアプリのタイムスタンプが同じか判定
is_dmg_same_version() {
    local dmg="$1"
    local mount_point
    mount_point=$(hdiutil attach "$dmg" -nobrowse -readonly -noverify 2>/dev/null \
        | grep '/Volumes/' | sed 's/.*\t//')
    [[ -z "$mount_point" ]] && return 1

    local app_in_dmg
    app_in_dmg=$(find "$mount_point" -maxdepth 2 -name "*.app" | head -1)
    if [[ -z "$app_in_dmg" ]]; then
        hdiutil detach "$mount_point" -quiet 2>/dev/null || true
        return 1
    fi

    local installed_app
    installed_app="$APPS_DIR/$(basename "$app_in_dmg")"
    local same=1
    if [[ -d "$installed_app" ]]; then
        local dmg_mtime installed_mtime
        dmg_mtime=$(stat -f %m "$app_in_dmg")
        installed_mtime=$(stat -f %m "$installed_app")
        [[ "$dmg_mtime" == "$installed_mtime" ]] && same=0
    fi

    hdiutil detach "$mount_point" -quiet 2>/dev/null || true
    return $same
}

remove_app() {
    local dmg="$1"
    local app_name
    app_name=$(basename "$dmg" .dmg)
    local app_path="$APPS_DIR/${app_name}.app"

    echo ""
    echo "==> $app_name を削除"
    quit_app "$app_name"

    if [[ -d "$app_path" ]]; then
        echo "  削除: $app_path"
        rm -rf "$app_path"
    else
        echo "  スキップ: $app_path が見つかりません"
    fi
}

uninstall_app() {
    local app_name="$1"
    local app_path="$APPS_DIR/${app_name}.app"

    echo ""
    echo "==> $app_name をアンインストール"
    quit_app "$app_name"

    if [[ -d "$app_path" ]]; then
        echo "  削除: $app_path"
        rm -rf "$app_path"
    else
        echo "  スキップ: $app_path が見つかりません"
    fi

}

clear_widget_cache() {
    echo ""
    echo "==> ウィジェットキャッシュをクリア..."
    killall NotificationCenter 2>/dev/null || true
    killall widgetextensionhost 2>/dev/null || true
    sleep 1
}

install_dmg() {
    local dmg="$1"
    local app_name
    app_name=$(basename "$dmg" .dmg)

    # タブ区切りの最終フィールド（スペース含むボリューム名に対応）
    local mount_point
    mount_point=$(hdiutil attach "$dmg" -nobrowse -readonly -noverify 2>/dev/null \
        | grep '/Volumes/' | sed 's/.*\t//')

    if [[ -z "$mount_point" ]]; then
        echo ""
        echo "  エラー: マウントに失敗しました ($dmg)" >&2
        return 1
    fi

    local app_in_dmg
    app_in_dmg=$(find "$mount_point" -maxdepth 2 -name "*.app" | head -1)

    if [[ -z "$app_in_dmg" ]]; then
        echo ""
        echo "  警告: .app が見つかりませんでした ($dmg)" >&2
        hdiutil detach "$mount_point" -quiet 2>/dev/null || true
        return 0
    fi

    local installed_name
    installed_name=$(basename "$app_in_dmg" .app)
    local installed_app="$APPS_DIR/${installed_name}.app"

    # インストール済み .app の更新日時と DMG 内 .app の更新日時を比較
    if ! $force && [[ -d "$installed_app" ]]; then
        local dmg_mtime installed_mtime
        dmg_mtime=$(stat -f %m "$app_in_dmg")
        installed_mtime=$(stat -f %m "$installed_app")
        if [[ "$dmg_mtime" == "$installed_mtime" ]]; then
            echo ""
            echo "==> $installed_name — スキップ（インストール済みと同じバージョン）"
            hdiutil detach "$mount_point" -quiet 2>/dev/null || true
            return 0
        fi
    fi

    echo ""
    echo "==> $installed_name をインストール"
    quit_app "$installed_name"
    echo "  インストール中..."
    cp -Rp "$app_in_dmg" "$APPS_DIR/"
    installed_apps+=("$installed_name")

    hdiutil detach "$mount_point" -quiet 2>/dev/null || true
}

relaunch_apps() {
    echo ""
    echo "==> アプリを起動してウィジェット拡張を登録..."
    for app_name in "${installed_apps[@]}"; do
        echo "  起動: $app_name"
        open "$APPS_DIR/${app_name}.app" 2>/dev/null || echo "  警告: 起動できませんでした: $app_name"
    done
    # ウィジェット拡張が登録されるまで待機
    sleep 3
}

_try_open_widget_with_python() {
    python3 - <<'PYEOF'
import subprocess, time, sys

try:
    import Quartz
except ImportError:
    sys.exit(1)

subprocess.run(['osascript', '-e', 'tell application "Finder" to activate'], check=False)
time.sleep(0.6)

display = Quartz.CGMainDisplayID()
x = Quartz.CGDisplayPixelsWide(display) // 2
y = Quartz.CGDisplayPixelsHigh(display) // 2

for etype in (Quartz.kCGEventRightMouseDown, Quartz.kCGEventRightMouseUp):
    e = Quartz.CGEventCreateMouseEvent(None, etype, (x, y), Quartz.kCGMouseButtonRight)
    Quartz.CGEventPost(Quartz.kCGHIDEventTap, e)
    time.sleep(0.05)

time.sleep(0.8)

for item in ['ウィジェットを編集…', 'Edit Widgets…',
             'ウィジェットを編集...', 'Edit Widgets...']:
    r = subprocess.run(
        ['osascript', '-e',
         f'tell application "System Events" to tell process "Finder" to click menu item "{item}" of menu 1'],
        capture_output=True
    )
    if r.returncode == 0:
        break
PYEOF
}

open_widget_editor() {
    echo ""
    echo "==> ウィジェット編集画面を開きます..."

    if ! _try_open_widget_with_python 2>/dev/null; then
        osascript -e 'tell application "Finder" to activate' 2>/dev/null || true
        echo "  (デスクトップを右クリック →「ウィジェットを編集...」を選択してください)"
    fi
}

# ── メイン処理 ──────────────────────────────────────

reinstall=false
force=false
uninstall=false

# オプション解析
args=()
for arg in "$@"; do
    case "$arg" in
        --reinstall|-r) reinstall=true ;;
        --force|-f)     force=true ;;
        --uninstall|-u) uninstall=true ;;
        -*) echo "不明なオプション: $arg" >&2; exit 1 ;;
        *) args+=("$arg") ;;
    esac
done

if $uninstall && $reinstall; then
    echo "エラー: --uninstall と --reinstall は同時に指定できません" >&2
    exit 1
fi

# ── アンインストールモード ───────────────────────────
if $uninstall; then
    app_names=()
    if (( ${#args[@]} > 0 )); then
        app_names=("${args[@]}")
    else
        # 引数なし: BUILD_DIR の DMG に対応するアプリをアンインストール
        for dmg in "$BUILD_DIR"/*.dmg; do
            [[ -f "$dmg" ]] && app_names+=("$(basename "$dmg" .dmg)")
        done
    fi

    if (( ${#app_names[@]} == 0 )); then
        echo "アンインストール対象が見つかりませんでした。"
        exit 1
    fi

    for app_name in "${app_names[@]}"; do
        uninstall_app "$app_name"
    done

    echo ""
    joined=$(IFS=', '; echo "${app_names[*]}")
    echo "完了! アンインストール済み: $joined"
    exit 0
fi

check_icloud_sync "$BUILD_DIR"

echo "Build フォルダ: $BUILD_DIR"
if $reinstall; then
    echo "モード: 再インストール（削除してからインストール）"
elif $force; then
    echo "モード: 強制インストール（バージョンチェックをスキップ）"
else
    echo "モード: 上書きインストール（同バージョンはスキップ）"
fi

dmg_files=()
if (( ${#args[@]} > 0 )); then
    for app_name in "${args[@]}"; do
        dmg="$BUILD_DIR/${app_name}.dmg"
        if [[ -f "$dmg" ]]; then
            dmg_files+=("$dmg")
        else
            echo "警告: ${app_name}.dmg が見つかりません" >&2
        fi
    done
else
    for dmg in "$BUILD_DIR"/*.dmg; do
        [[ -f "$dmg" ]] || continue
        dmg_files+=("$dmg")
    done
fi

if (( ${#dmg_files[@]} == 0 )); then
    echo ""
    echo "DMG ファイルが見つかりませんでした。"
    exit 1
fi

if $reinstall; then
    # 同バージョンの DMG は削除前に除外
    to_reinstall=()
    for dmg in "${dmg_files[@]}"; do
        if ! $force && is_dmg_same_version "$dmg"; then
            echo ""
            echo "==> $(basename "$dmg" .dmg) — スキップ（インストール済みと同じバージョン）"
        else
            to_reinstall+=("$dmg")
        fi
    done
    dmg_files=("${to_reinstall[@]}")

    if (( ${#dmg_files[@]} > 0 )); then
        # フェーズ 1: 対象アプリを終了・削除
        for dmg in "${dmg_files[@]}"; do
            remove_app "$dmg"
        done

        # フェーズ 2: ウィジェットキャッシュをクリア
        clear_widget_cache
    fi
fi

# フェーズ 3: 全アプリをインストール（quit は install_dmg 内で実行）
for dmg in "${dmg_files[@]}"; do
    install_dmg "$dmg"
done

if (( ${#installed_apps[@]} == 0 )); then
    echo ""
    echo "すべてのアプリは最新版がインストール済みです。"
    exit 0
fi

# フェーズ 4: アプリを起動してウィジェット拡張を登録
relaunch_apps

# フェーズ 5: ウィジェット編集画面を開く
open_widget_editor

echo ""
joined=$(IFS=', '; echo "${installed_apps[*]}")
echo "完了! インストール済み: $joined"
