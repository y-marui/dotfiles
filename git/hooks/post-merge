#!/usr/bin/env bash
# グローバル post-merge フック（git pull 後に自動実行）
# dotfiles リポジトリの pull 後に Brewfile.cache と Brewfile の差分があれば警告
# それ以外のリポジトリでは何もしない

REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# dotfiles リポジトリ以外はスキップ
[[ "$REPO_DIR" != "$DOTFILES_DIR" ]] && exit 0

DIFF="${DOTFILES_DIR}/macos/diff_brewfile.sh"
CACHE="${DOTFILES_DIR}/macos/Brewfile.cache"

[[ -f "$DIFF" && -f "$CACHE" ]] || exit 0

# 差分チェック → 差分あれば警告（ブロックはしない）
if ! bash "$DIFF" >/dev/null 2>&1; then
  echo "⚠️  brew: pull 後に Brewfile.cache と Brewfile に差分があります。make brew-diff で確認してください。" >&2
fi
exit 0
