#!/usr/bin/env bash
DOTFILES_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
SYNC="$DOTFILES_DIR/macos/dock-sync.sh"
SNAPSHOT="$DOTFILES_DIR/macos/dock-snapshot.txt"

[[ -f "$SYNC" && -f "$SNAPSHOT" ]] || exit 0
command -v dockutil &>/dev/null || exit 0

if ! bash "$SYNC" --check 2>/dev/null; then
  echo "⚠️  Dock/Sidebar の変更が検出されています。" >&2
  echo "    make dock-sync を実行して dock.sh を更新してからコミット・push してください。" >&2
  # 警告のみ（push はブロックしない）
fi
exit 0
