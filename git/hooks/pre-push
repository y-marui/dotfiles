#!/usr/bin/env bash
# グローバル pre-push フック
# dotfiles リポジトリの push 前に Brewfile.cache と Brewfile の差分があれば push をブロック
# それ以外のリポジトリでは何もしない

REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

# dotfiles リポジトリ以外はスキップ
[[ "$REPO_DIR" != "$DOTFILES_DIR" ]] && exit 0

DIFF="${DOTFILES_DIR}/macos/diff_brewfile.sh"
CACHE="${DOTFILES_DIR}/macos/Brewfile.cache"

[[ -f "$DIFF" && -f "$CACHE" ]] || exit 0

# 差分チェック → 差分あれば push をブロック
if ! bash "$DIFF" 2>/dev/null; then
  echo "⚠️  Brewfile.cache と Brewfile に差分があります。" >&2
  echo "    make brew-sync または make brew を実行してから push してください。" >&2
  exit 1
fi
exit 0
