#!/usr/bin/env bash
set -euo pipefail

SKIP_MSG="他人管理のリポジトリの場合はスキップできます: git config hooks.skip-policy-check true"

# --- 他人管理リポジトリのスキップ ---
if [[ "$(git config --local hooks.skip-policy-check 2>/dev/null)" == "true" ]]; then
  exit 0
fi

# --- identity チェック ---
name="$(git config user.name)"
email="$(git config user.email)"

if [[ "${name}" == "anonymous" || "${email}" == "anonymous" ]]; then
  echo "エラー: user.name / user.email が anonymous のままです。" >&2
  echo "${HOME}/.gitconfig.d/local または該当の \${HOME}/.gitconfig.d/{org} に設定してください。" >&2
  exit 1
fi

# --- .env ファイルのステージング検知 ---
staged_env="$(git diff --cached --name-only | grep -E '(^|/)\.env(\.[^.]+)?$' | grep -vE '\.(example|sample|template)$' || true)"
if [[ -n "${staged_env}" ]]; then
  echo "エラー: .env ファイルがステージされています:" >&2
  echo "${staged_env}" >&2
  exit 1
fi

# --- SSH 秘密鍵ヘッダーの検知 ---
if git diff --cached | grep -q '\-\-\-\-\-BEGIN.*PRIVATE KEY\-\-\-\-\-'; then
  echo "エラー: SSH 秘密鍵らしき内容が含まれています。" >&2
  exit 1
fi

# --- 開発ポリシー準拠チェック ---
if [[ ! -f ".pre-commit-config.yaml" ]]; then
  echo "エラー: .pre-commit-config.yaml がありません。開発ポリシーに準拠していません。" >&2
  echo "${SKIP_MSG}" >&2
  exit 1
fi

# セキュリティ必須項目のチェック
missing=()
grep -q 'gitleaks' .pre-commit-config.yaml              || missing+=("gitleaks")
grep -q 'detect-private-key' .pre-commit-config.yaml    || missing+=("detect-private-key")
grep -qE 'detect-dotenv|\.env' .pre-commit-config.yaml  || missing+=(".env チェック")

if [[ ${#missing[@]} -gt 0 ]]; then
  echo "エラー: .pre-commit-config.yaml にセキュリティ必須項目が不足しています: ${missing[*]}" >&2
  echo "${SKIP_MSG}" >&2
  exit 1
fi

# pre-commit run（core.hooksPath 経由なので直接実行）
if command -v pre-commit &>/dev/null; then
  pre-commit run --hook-stage pre-commit
else
  echo "エラー: pre-commit コマンドが見つかりません。" >&2
  echo "  pip install pre-commit  または  brew install pre-commit" >&2
  echo "${SKIP_MSG}" >&2
  exit 1
fi
