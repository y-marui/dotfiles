# git/gitconfig
# 組織・アカウント別の [user] は ~/.gitconfig.d/{name} に記載してください。
#
# ~/.gitconfig.d/public の例（y-marui/ 配下）:
#   [user]
#       name = Your Name
#       email = your-public@example.com
#       # signingkey = XXXXXXXX  # GPG使用時
#
# ~/.gitconfig.d/local の例（フォールバック）:
#   [user]
#       name = Your Name
#       email = your@example.com

[core]
	excludesfile = ~/.gitignore_global
	editor = vim -c "set fenc=utf-8"
	symlinks = true
	quotepath = false

# エイリアス
[include]
	path = ./gitconfig.d/aliases.gitconfig

# 組織別設定（~/.gitconfig.d/includes に [includeIf] を記載、private gist で管理）
# ~/.gitconfig.d/includes の例:
#   [includeIf "gitdir:~/src/github.com/<public-org>/"]
#       path = ~/.gitconfig.d/public
#   [includeIf "gitdir:~/src/github.com/<private-org>/"]
#       path = ~/.gitconfig.d/private
#   [includeIf "gitdir:~/src/git.overleaf.com/"]
#       path = ~/.gitconfig.d/overleaf
[include]
	path = ~/.gitconfig.d/includes
# ローカル設定（[user] name/email/signingkey 等）
[include]
	path = ~/.gitconfig.d/local

[ghq]
	root = ~/src

[merge]
	ff = false

[pull]
	ff = only

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[difftool "sourcetree"]
	cmd = opendiff "$LOCAL" "$REMOTE"

[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh "$LOCAL" "$REMOTE" -ancestor "$BASE" -merge "$MERGED"
	trustExitCode = true
